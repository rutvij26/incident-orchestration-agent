TEMPORAL_ADDRESS=localhost:7233
LOKI_URL=http://localhost:3100
# LogQL selector used by the agent workflow. Change this for your own log stream.
LOKI_QUERY={job="demo-services"}
# Comma-separated list of active source connectors (log backends to query).
# Currently supported: loki. Add multiple for fan-out log aggregation.
SOURCE_CONNECTORS=loki
POSTGRES_URL=postgresql://agentic:agentic@localhost:5432/agentic
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=incident-agent
# Minimum severity to escalate to GitHub Issues: low | medium | high | critical | none
AUTO_ESCALATE_FROM=high
LLM_PROVIDER=auto
# Optional: comma-separated ordered fallback chain, overrides LLM_PROVIDER.
# Example: LLM_CONNECTORS=openai,anthropic (try OpenAI first, fall back to Anthropic)
# LLM_CONNECTORS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_PROVIDER=auto
# Optional: single connector override for embeddings, overrides EMBEDDING_PROVIDER.
# Example: EMBEDDING_CONNECTOR=gemini
# EMBEDDING_CONNECTOR=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=6
RAG_MIN_SCORE=0.2
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_REPO_PATH=
# Optional: scope RAG indexing to a subdirectory of the repo (e.g. apps/demo-services).
# Paths are still stored relative to the repo root so auto-fix diffs are correct.
RAG_REPO_SUBDIR=
RAG_REPO_CACHE_DIR=.agentic/repos
RAG_REPO_REFRESH=pull
AUTO_FIX_MODE=off
AUTO_FIX_SEVERITY=all
AUTO_FIX_REPO_PATH=
AUTO_FIX_BRANCH_PREFIX=agentic-fix
AUTO_FIX_TEST_COMMAND=npm run test
AUTO_FIX_INSTALL_COMMAND=npm install --include=dev
AUTO_FIX_SANDBOX_IMAGE=node:20-slim
GITHUB_DEFAULT_BRANCH=main
AUTO_FIX_MIN_SCORE=0.5
AUTO_FIX_SKIP_AFTER_FAILURES=1

# GitHub Issue creation
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
REPO_URL=
GIT_USER_NAME=
GIT_USER_EMAIL=

# Grafana (used by Docker Compose observability stack)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Demo service
LOG_PATH=apps/demo-services/logs/demo-services.log
SIMULATE_INCIDENTS=true
# Set to "true" to flood logs with critical-severity /api/orders crashes every 3 s
# (triggers the auto-fix agent quickly in demos)
SIMULATE_CRITICAL_BUG=false
PORT=4000
DEMO_OTEL_SERVICE_NAME=demo-services
DEMO_HEALTH_URL=http://localhost:4000/health
